<?xml version="1.0"?>
<package format="3">
  <name>nano_gicp</name>
  <version>1.0.0</version>
  <description>ROS 2 ament wrapper for Nano-GICP used by FAST-LIO-SAM-SC-QN.</description>

  <maintainer email="robocon@example.com">GDUT Robocon</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>
  <build_depend>eigen</build_depend>
  <build_depend>libpcl-all-dev</build_depend>
